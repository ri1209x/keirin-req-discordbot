# Discord Bot Token
# https://discord.com/developers/applications でBotを作成して取得
DISCORD_TOKEN=

# Google AI Studio API Key (オプション：AIアドバイス機能に使用)
# https://aistudio.google.com/app/apikey で取得
# 未設定の場合はデフォルトのアドバイスが表示されます
GOOGLE_AI_API_KEY=

# Anthropic API Key (オプション：Claudeアドバイス機能に使用)
# https://console.anthropic.com/ で取得
# 未設定の場合はClaudeは使用されません
ANTHROPIC_API_KEY=
